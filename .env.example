# Copy this file to .env and fill in real values. Never commit .env itself.

# Required. Generate a real one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret

# The domain Caddy will request a TLS certificate for. Use "localhost" for
# local testing (Caddy issues a self-signed cert automatically for that case).
# Only used by Option B (Caddy with its own real cert). Not needed for Option A
# (Cloudflare Tunnel) — that path doesn't use this compose file at all.
DOMAIN=localhost
