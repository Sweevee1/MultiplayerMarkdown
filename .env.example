# Copy this file to .env and fill in real values. Never commit .env itself.

# Required. Generate a real one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret

# Optional, one-time bootstrap: if both are set, this account is created as
# an admin the first time the server starts (safe to leave set permanently —
# it's skipped on every later start once the account already exists, so it
# never resets the password). Lets you create your first account without
# ever opening a terminal. You can remove these two lines after first boot,
# or just leave them — either way is fine.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# The domain Caddy will request a TLS certificate for. Use "localhost" for
# local testing (Caddy issues a self-signed cert automatically for that case).
# Only used by Option B (Caddy with its own real cert). Not needed for Option A
# (Cloudflare Tunnel) — that path doesn't use this compose file at all.
DOMAIN=localhost
